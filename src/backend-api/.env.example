DATABASE_URL="postgresql://ticketbox:ticketbox123@localhost:5433/ticketbox?schema=public"
DIRECT_URL="postgresql://ticketbox:ticketbox123@localhost:5433/ticketbox?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_ISSUER="ticketbox-backend"
JWT_EXPIRES_IN_SECONDS="3600"
PORT="3000"
REDIS_URL="redis://localhost:6379/0"
PUBLIC_CONCERT_CACHE_TTL_SECONDS="60"
INVENTORY_SUMMARY_CACHE_TTL_SECONDS="5"
CACHE_TTL_JITTER_RATIO="0.15"
CACHE_MISS_QUERY_BUDGET="8"
WEBHOOK_SIGNING_SECRET="replace-with-a-payment-webhook-secret"
PAYMENT_PROVIDER_TIMEOUT_MS="3000"
PAYMENT_PROVIDER_MAX_CONCURRENCY="10"
PAYMENT_CIRCUIT_FAILURE_THRESHOLD="5"
PAYMENT_CIRCUIT_COOLDOWN_MS="30000"
PAYMENT_RECONCILIATION_BATCH_SIZE="20"
PAYMENT_RECONCILIATION_LEASE_MS="30000"
PAYMENT_RECONCILIATION_RETRY_MS="30000"
PAYMENT_PENDING_RECONCILIATION_AGE_MS="60000"
MOCK_PAYMENT_MODE="success"
MOCK_PAYMENT_DELAY_MS="0"

# Concert poster local storage (default: storage/concert-posters)
CONCERT_POSTER_STORAGE_DIR="storage/concert-posters"

# AI Artist Bio RabbitMQ queue, MinIO object storage and mock provider
ARTIST_BIO_RABBITMQ_URL="amqp://ticketbox:ticketbox123@localhost:5672"
ARTIST_BIO_QUEUE_NAME="artist-bio.jobs"
ARTIST_BIO_EXCHANGE_NAME="artist-bio.jobs"
ARTIST_BIO_ROUTING_KEY="process"
ARTIST_BIO_DLX_NAME="artist-bio.jobs.dlx"
ARTIST_BIO_DLQ_NAME="artist-bio.jobs.dlq"
ARTIST_BIO_S3_ENDPOINT="http://localhost:9000"
ARTIST_BIO_S3_REGION="us-east-1"
ARTIST_BIO_S3_ACCESS_KEY_ID="ticketbox"
ARTIST_BIO_S3_SECRET_ACCESS_KEY="ticketbox123"
ARTIST_BIO_S3_BUCKET="artist-bio-pdfs"
ARTIST_BIO_S3_FORCE_PATH_STYLE="true"
ARTIST_BIO_MOCK_MODE="success"
