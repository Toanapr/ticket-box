generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  audience
  organizer
  scanner
  system_admin
  service_account
}

enum UserStatus {
  active
  disabled
}

enum ConcertStatus {
  draft
  published
  canceled
}

model Organization {
  id       String    @id @default(uuid()) @db.Uuid
  name     String
  users    User[]
  concerts Concert[]

  @@map("organizations")
}

model User {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String?           @map("organization_id") @db.Uuid
  email          String            @unique
  role           UserRole
  passwordHash   String            @map("password_hash")
  status         UserStatus        @default(active)
  organization   Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  quotas         UserTicketQuota[]

  @@index([organizationId])
  @@map("users")
}

model Concert {
  id                  String        @id @default(uuid()) @db.Uuid
  organizationId      String        @map("organization_id") @db.Uuid
  title               String
  venue               String
  artistName          String        @map("artist_name")
  description         String?
  startAt             DateTime      @map("start_at") @db.Timestamptz(6)
  status              ConcertStatus @default(draft)
  seatingMapObjectKey String        @map("seating_map_object_key")
  publishedArtistBio  String        @map("published_artist_bio")
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  ticketTypes         TicketType[]

  @@index([status, startAt])
  @@index([organizationId])
  @@map("concerts")
}

model TicketType {
  id           String            @id @default(uuid()) @db.Uuid
  concertId    String            @map("concert_id") @db.Uuid
  zoneCode     String            @map("zone_code")
  name         String
  price        Decimal           @db.Decimal(12, 2)
  capacity     Int
  perUserLimit Int               @map("per_user_limit")
  saleStartAt  DateTime          @map("sale_start_at") @db.Timestamptz(6)
  saleEndAt    DateTime          @map("sale_end_at") @db.Timestamptz(6)
  concert      Concert           @relation(fields: [concertId], references: [id], onDelete: Cascade)
  inventory    InventoryCounter?
  quotas       UserTicketQuota[]

  @@index([concertId])
  @@map("ticket_types")
}

model InventoryCounter {
  ticketTypeId  String     @id @map("ticket_type_id") @db.Uuid
  totalCapacity Int        @map("total_capacity")
  reservedCount Int        @default(0) @map("reserved_count")
  soldCount     Int        @default(0) @map("sold_count")
  version       Int        @default(0)
  ticketType    TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@map("inventory_counters")
}

model UserTicketQuota {
  userId        String     @map("user_id") @db.Uuid
  ticketTypeId  String     @map("ticket_type_id") @db.Uuid
  reservedCount Int        @default(0) @map("reserved_count")
  paidCount     Int        @default(0) @map("paid_count")
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketType    TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@id([userId, ticketTypeId])
  @@index([ticketTypeId])
  @@map("user_ticket_quotas")
}
