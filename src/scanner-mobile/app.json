{
  "expo": {
    "name": "scanner-mobile",
    "slug": "scanner-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "androidNavigationBar": {
      "visible": "sticky-immersive",
      "barStyle": "light-content",
      "backgroundColor": "#09090b",
      "enforceContrast": false
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow TicketBox to access your camera for scanning tickets."
        }
      ],
      [
        "expo-navigation-bar",
        {
          "visibility": "hidden",
          "behavior": "overlay-swipe",
          "position": "absolute",
          "backgroundColor": "#09090b",
          "barStyle": "light",
          "legacyVisible": "sticky-immersive"
        }
      ]
    ]
  }
}
