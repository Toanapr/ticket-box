{
  "expo": {
    "name": "scanner-mobile",
    "slug": "scanner-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow TicketBox to access your camera for scanning tickets."
        }
      ]
    ]
  }
}
